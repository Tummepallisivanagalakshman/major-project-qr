  {
    "id": "TC010",
    "title": "Deny an invalid QR code scan with a clear reason and no meal record insertion",
    "description": "Verifies scanning a QR code that is not a valid app-issued student meal QR is denied with a reason and does not create a new meal record.",
    "category": "QR Scanner (Admin)",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Fill {{LOGIN_USER}} into the email field"
      },
      {
        "type": "action",
        "description": "Fill {{LOGIN_PASSWORD}} into the password field"
      },
      {
        "type": "action",
        "description": "Submit the login form"
      },
      {
        "type": "action",
        "description": "Open the QR scanner camera view"
      },
      {
        "type": "action",
        "description": "Scan a clearly invalid QR code value (non-app code) using a test QR image displayed on-screen"
      },
      {
        "type": "assertion",
        "description": "Verify an access denied result is shown with a reason"
      },
      {
        "type": "action",
        "description": "Navigate to the meal logs view"
      },
      {
        "type": "assertion",
        "description": "Verify no new meal record was added as a result of the invalid scan"
      }
    ],
    "priority": "High"
  },
