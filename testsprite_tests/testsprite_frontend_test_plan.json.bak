  {
    "id": "TC007",
    "title": "Student can sign up and reach Student Dashboard",
    "description": "Verifies a new student can register by providing required details and is redirected to the student dashboard with a success confirmation visible.",
    "category": "Student Registration",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /signup"
      },
      {
        "type": "action",
        "description": "Fill Test Student into the full name field"
      },
      {
        "type": "action",
        "description": "Fill student+{{TIMESTAMP}}@example.com into the email field"
      },
      {
        "type": "action",
        "description": "Fill TestPassword123! into the password field"
      },
      {
        "type": "action",
        "description": "Fill STU-{{TIMESTAMP}} into the student ID field"
      },
      {
        "type": "action",
        "description": "Fill 5550101 into the phone field"
      },
      {
        "type": "action",
        "description": "Submit the signup form"
      },
      {
        "type": "assertion",
        "description": "Verify the user lands on the student dashboard"
      },
      {
        "type": "assertion",
        "description": "Verify a signup success confirmation is visible"
      }
    ],
    "priority": "High"
  },
