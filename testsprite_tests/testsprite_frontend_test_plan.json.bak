  {
    "id": "TC051",
    "title": "Admin scans student QR code and sees student details with payment status",
    "description": "Verifies that when an admin scans a valid student QR code, the scan result overlay displays the student's full name, student ID, room number, phone, and payment status (paid/total fees and percentage).",
    "category": "QR Scanner (Admin) - Student Details",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Fill {{LOGIN_USER}} into the email field"
      },
      {
        "type": "action",
        "description": "Fill {{LOGIN_PASSWORD}} into the password field"
      },
      {
        "type": "action",
        "description": "Submit the login form"
      },
      {
        "type": "action",
        "description": "Click the Live Scanner button to open the QR scanner modal"
      },
      {
        "type": "action",
        "description": "Scan a valid student QR code generated by the app"
      },
      {
        "type": "assertion",
        "description": "Verify the scan result overlay appears with ACCESS GRANTED or ACCESS DENIED status"
      },
      {
        "type": "assertion",
        "description": "Verify the scan result overlay shows the student full name"
      },
      {
        "type": "assertion",
        "description": "Verify the scan result overlay shows the student ID"
      },
      {
        "type": "assertion",
        "description": "Verify the scan result overlay shows the fee payment status (paid amount, total fees, and percentage)"
      }
    ],
    "priority": "High"
  },
